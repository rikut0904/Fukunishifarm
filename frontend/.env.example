# Browser-side API endpoint used by Next.js pages/components at build time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Internal API endpoint used by `frontend/proxy.ts` when running in Docker.
API_INTERNAL_BASE_URL=http://api:8080

# microCMS admin links used by the admin dashboard cards.
MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_BLOG_ENDPOINT=blogs
MICROCMS_NEWS_ENDPOINT=news
